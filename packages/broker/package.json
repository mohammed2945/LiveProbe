{
  "name": "@liveprobe/broker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "fake-agent": "pnpm run build && node dist/scripts/fake-agent.js",
    "start": "node dist/src/index.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "pnpm --filter @doomslayer2945/liveprobe-mcp run build && tsc --project tsconfig.json --noEmit && tsc --project tsconfig.test.json"
  },
  "dependencies": {
    "@clerk/backend": "^3.12.0",
    "@doomslayer2945/liveprobe-mcp": "workspace:*",
    "@jridgewell/trace-mapping": "^0.3.31",
    "fastify": "^5.10.0",
    "pg": "^8.16.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.15.5",
    "typescript": "^7.0.2"
  }
}
