{
  "name": "liveprobe",
  "version": "0.1.0",
  "private": true,
  "description": "AI-native live production debugger",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "audit:readonly": "node scripts/readonly-audit.mjs",
    "audit:redaction": "sh scripts/redaction-audit.sh",
    "bench": "pnpm --filter @doomslayer2945/liveprobe-node run bench && sh scripts/python312.sh python/sdk/benchmarks/monitoring_overhead.py",
    "build": "pnpm --recursive run build",
    "demo": "make demo",
    "demo:down": "make demo-down",
    "dev": "tsx server.ts",
    "e2e:jvm": "make e2e-jvm",
    "e2e:node": "make e2e-node",
    "e2e:python": "make e2e-python",
    "fixtures:validate": "node scripts/validate-fixtures.mjs",
    "frontend:build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "frontend:lint": "tsc --project tsconfig.json --noEmit",
    "frontend:start": "node dist/server.cjs",
    "test": "pnpm run fixtures:validate && pnpm run typecheck && pnpm run test:packages",
    "test:packages": "pnpm --recursive run test",
    "typecheck": "pnpm --recursive run typecheck"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.110.7",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.9.2",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
